   "source": [
    "import numpy as np\n",
    "from numpy import random \n",
    "rnp=random.default_rng(50)\n",
    "N=1000000\n",
    "count=0\n",
    "for i in range(N):\n",
    "    x=rnp.uniform(-1,1)\n",
    "    y=rnp.uniform(-1,1)\n",
    "    if (x**2+y**2)<=1:\n",
    "        count+=1\n",
    "pi=4*count/N\n",
    "print(pi)"
   ]
  }
 ],
