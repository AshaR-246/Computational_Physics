   "source": [
    "def f(x,y):\n",
    "    return (2*x-y)/(x+2)\n",
    "n=10\n",
    "y0=4\n",
    "x0=0\n",
    "h=0.01\n",
    "for i in range(1,n+2):\n",
    "    y1=y0+h*f(x0,y0)\n",
    "    print(f\"y_{i-1}={y0:.5f}\")\n",
    "    y0=y1\n",
    "    x0+=h\n"
   ]
  }
